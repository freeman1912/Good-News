# Optional for automated AI scoring. The site, RSS feeds, and manual publishing
# work without these values. DeepSeek is checked first because it is cheaper.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI fallback for automated AI scoring.
OPENAI_API_KEY=
OPENAI_MODEL=
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_GITHUB_NEW_ISSUE_URL=https://github.com/freeman1912/Good-News/issues/new
PUBLIC_GITHUB_ISSUE_TEMPLATE_URL=https://github.com/freeman1912/Good-News/issues/new?template=good-news-lead.yml
PUBLIC_GITHUB_ISSUE_URL=https://github.com/freeman1912/Good-News/issues/new

# Optional OpenAI-compatible endpoint for automated AI scoring.
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MAX_TOKENS=1200

# Keep false unless you intentionally want high-confidence AI-scored items
# to be written into data/news during local experiments.
ALLOW_AUTOPUBLISH=false

# Optional local testing controls.
# INGEST_SCORE_LIMIT writes to data/candidates/YYYY-MM-DD.scored.sample.json by default.
# INGEST_REROUTE_ONLY re-applies routing rules to an existing scored file without API calls.
INGEST_SCORE_LIMIT=
INGEST_SCORE_OUTPUT=
INGEST_REROUTE_ONLY=false

# Optional analytics variables for a later phase.
PUBLIC_ANALYTICS_PROVIDER=
PUBLIC_PLAUSIBLE_DOMAIN=
