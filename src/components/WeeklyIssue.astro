---
import type { WeeklyIssue as WeeklyIssueType } from "@/lib/types";
import NewsEntry from "./NewsEntry.astro";

interface Props {
  issue: WeeklyIssueType;
  items?: WeeklyIssueType["items"];
  showWatchlist?: boolean;
  showHeader?: boolean;
  compact?: boolean;
}

const { issue, items = issue.items, showWatchlist = true, showHeader = true, compact = false } = Astro.props;
const weekLabel = `${issue.weekStart} 至 ${issue.weekEnd}`;
---

<section class="grid gap-5" aria-labelledby={`issue-${issue.id}`}>
  {
    showHeader && (
      <header class="border-b border-border pb-4">
        <p class="text-sm font-medium text-primary">{issue.id} · {weekLabel}</p>
        <h2 id={`issue-${issue.id}`} class="mt-2 text-2xl font-semibold leading-tight text-ink">{issue.title}</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-muted">{issue.intro}</p>
      </header>
    )
  }

  {
    items.length === 0 ? (
      <p class="rounded-lg border border-dashed border-border bg-surface p-5 text-sm text-muted">
        这一期没有符合当前筛选条件的条目。
      </p>
    ) : (
      <div class:list={[compact ? "border-y border-border" : "border-l border-border pl-4"]}>
        {items.map((item, index) => (
          <div class="grid gap-2">
            <NewsEntry item={item} compact={compact} index={index + 1} />
            {item.weeklyNote && (
              <p class:list={[
                "text-sm leading-6 text-muted last:border-b-0",
                compact ? "border-b border-border pb-5 sm:ml-[3.25rem]" : "-mt-2 border-b border-border pb-4",
              ]}>
                <span class="font-medium text-ink">提醒：</span>{item.weeklyNote}
              </p>
            )}
          </div>
        ))}
      </div>
    )
  }

  {
    showWatchlist && issue.watchlist && issue.watchlist.length > 0 && (
      <aside class="border-t border-border pt-5">
        <h3 class="text-base font-semibold text-ink">仍在观察，不进入本期</h3>
        <div class="mt-3 grid gap-3">
          {issue.watchlist.map((item) => (
            <article class="border-t border-border pt-3 first:border-t-0 first:pt-0">
              <p class="text-sm font-medium text-ink">{item.title}</p>
              <p class="mt-1 text-sm leading-6 text-muted">{item.reason}</p>
              <p class="mt-1 text-sm leading-6 text-muted">
                <span class="font-medium text-ink">待确认：</span>{item.followUpQuestion}
              </p>
              {item.sourceUrl && (
                <a class="mt-2 inline-flex text-sm font-medium text-primary hover:underline" href={item.sourceUrl} target="_blank" rel="noopener noreferrer">
                  查看线索来源
                </a>
              )}
            </article>
          ))}
        </div>
      </aside>
    )
  }
</section>
