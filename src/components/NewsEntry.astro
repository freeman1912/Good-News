---
import { getRegionLabel, getTopicLabel } from "@/lib/categories";
import type { PublishedNewsItem } from "@/lib/types";
import VerificationNote from "./VerificationNote.astro";

interface Props {
  item: PublishedNewsItem;
  compact?: boolean;
  index?: number;
}

const { item, compact = false, index } = Astro.props;
const publishedDate = item.publishedAt
  ? new Intl.DateTimeFormat("zh-CN", {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(item.publishedAt))
  : null;
---

<article class:list={[
  "group relative grid border-border bg-transparent",
  compact ? "gap-3 border-t py-6 first:border-t-0 sm:grid-cols-[3.25rem_1fr]" : "gap-3 border-b py-5 last:border-b-0",
]}>
  {compact && (
    <div class="text-sm font-semibold tabular-nums text-primary sm:pt-1">
      {String(index ?? 1).padStart(2, "0")}
    </div>
  )}

  <div class="grid gap-3">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs">
    <span class="font-medium text-primary">{getTopicLabel(item.topic)}</span>
    <span class="text-muted">/</span>
    <span class="text-muted">{getRegionLabel(item.region)}</span>
    {item.isExample && <span class="rounded-sm border border-border px-2 py-0.5 text-muted">示例数据</span>}
    {publishedDate && <span class="text-muted">{publishedDate}</span>}
  </div>

  <div class="grid gap-3">
    <h3 class:list={[
      "font-semibold leading-snug text-ink transition group-hover:text-primary",
      compact ? "text-lg sm:text-xl" : "text-xl",
    ]}>{item.title}</h3>
    <p class="text-sm leading-7 text-muted">{item.summary}</p>
  </div>

  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted">
    <span>来源：<a class="text-primary hover:underline" href={item.sourceUrl} target="_blank" rel="noopener noreferrer">{item.sourceName}</a></span>
    <a class="font-medium text-primary hover:underline" href={item.originalUrl} target="_blank" rel="noopener noreferrer">查看原文</a>
    <span>{item.sourceCount} 个来源</span>
  </div>

  {
    compact ? (
      <details class="group/details border-t border-border pt-3">
        <summary class="cursor-pointer select-none text-sm font-medium text-primary marker:text-muted">
          为什么是好消息 / 核实说明
        </summary>
        <div class="mt-3">
          <VerificationNote whyGood={item.whyGood} verificationNote={item.verificationNote} />
        </div>
      </details>
    ) : (
      <div>
        <VerificationNote whyGood={item.whyGood} verificationNote={item.verificationNote} />
      </div>
    )
  }
  </div>
</article>
