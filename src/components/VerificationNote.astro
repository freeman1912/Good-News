---
interface Props {
  whyGood: string;
  verificationNote: string;
}

const { whyGood, verificationNote } = Astro.props;
---

<div class="grid gap-3 border-l-2 border-tertiary/70 bg-surface/55 py-3 pl-4 text-sm leading-6 sm:grid-cols-2 sm:gap-5">
  <div>
    <p class="text-xs font-semibold text-primary">为什么是好消息</p>
    <p class="mt-1 text-ink/90">{whyGood}</p>
  </div>
  <div>
    <p class="text-xs font-semibold text-primary">核实说明</p>
    <p class="mt-1 text-muted">{verificationNote}</p>
  </div>
</div>
