---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WeeklyIssue from "@/components/WeeklyIssue.astro";
import { topicDefinitions } from "@/lib/categories";
import { getAllWeeklyIssues } from "@/lib/weekly";
import type { TopicSlug } from "@/lib/types";

export function getStaticPaths() {
  return topicDefinitions.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const issues = (await getAllWeeklyIssues())
  .map((issue) => ({
    issue,
    items: issue.items.filter((item) => item.topic === (topic.slug as TopicSlug)),
  }))
  .filter(({ items }) => items.length > 0);
---

<BaseLayout title={`${topic.label} - 好消息周报`}>
  <section class="mx-auto grid max-w-5xl gap-8 px-4 py-8 sm:px-6 sm:py-10">
    <header class="border-b border-border pb-6">
      <p class="text-sm text-muted">主题分类</p>
      <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="text-3xl font-bold text-ink sm:text-4xl">{topic.label}</h1>
          <p class="mt-4 max-w-2xl text-base leading-8 text-muted">{topic.description}</p>
        </div>
        <a class="rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-hover" href={topic.rssPath}>
          订阅这个主题
        </a>
      </div>
    </header>

    {
      issues.length === 0 ? (
        <p class="rounded-lg border border-dashed border-border bg-surface p-5 text-sm text-muted">这个主题暂时还没有入选条目。</p>
      ) : (
        <div class="grid gap-8">
          {issues.map(({ issue, items }) => <WeeklyIssue issue={issue} items={items} showWatchlist={false} />)}
        </div>
      )
    }
  </section>
</BaseLayout>
