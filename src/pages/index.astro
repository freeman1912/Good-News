---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WeeklyIssue from "@/components/WeeklyIssue.astro";
import { getAllWeeklyIssues } from "@/lib/weekly";

const issues = await getAllWeeklyIssues();
const latestIssue = issues[0] ?? null;
const itemCount = latestIssue?.items.length ?? 0;
const issueNumber = latestIssue ? issues.length : 0;
const weekMatch = latestIssue?.id.match(/^(\d{4})-W(\d{2})$/);
const issueLabel = weekMatch ? `${weekMatch[1]} 年第 ${Number(weekMatch[2])} 周` : latestIssue?.id;
---

<BaseLayout>
  <section class="mx-auto grid max-w-4xl gap-6 px-4 py-8 sm:px-6 sm:py-10">
    <section aria-labelledby="issue-heading" class="grid gap-5">
      {
        !latestIssue ? (
          <article class="rounded-lg border border-dashed border-border bg-surface p-5">
            <p class="text-sm text-muted">还没有发布周报。我们宁愿少发，也不为了凑数降低标准。</p>
          </article>
        ) : (
          <>
            <header class="border-b border-border pb-5">
              <p class="text-sm font-medium text-primary">{issueLabel}</p>
              <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <h1 id="issue-heading" class="text-3xl font-semibold leading-tight text-ink sm:text-4xl">
                    第 {issueNumber} 期
                  </h1>
                  <p class="mt-2 text-sm leading-6 text-muted">
                    {latestIssue.weekStart} 至 {latestIssue.weekEnd}
                  </p>
                </div>
                <div class="flex flex-wrap items-center gap-3 text-sm">
                  <span class="border-l border-tertiary pl-3 font-medium text-primary">{itemCount} 条</span>
                  <a class="font-medium text-primary hover:underline" href="/rss">RSS</a>
                  <a class="font-medium text-primary hover:underline" href="/submit">提交线索</a>
                </div>
              </div>
            </header>
            <WeeklyIssue issue={latestIssue} showHeader={false} compact />
          </>
        )
      }
    </section>
  </section>
</BaseLayout>
