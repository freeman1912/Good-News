---
import RssLinkBlock from "@/components/RssLinkBlock.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { topicDefinitions } from "@/lib/categories";
---

<BaseLayout title="RSS 订阅 - 好消息周报">
  <section class="mx-auto grid max-w-4xl gap-8 px-4 py-8 sm:px-6 sm:py-10">
    <header class="border-b border-border pb-6">
      <p class="text-sm text-muted">RSS</p>
      <h1 class="mt-2 text-3xl font-bold text-ink sm:text-4xl">RSS 订阅</h1>
      <p class="mt-4 max-w-2xl text-base leading-8 text-muted">
        你可以订阅全部周报条目，也可以只订阅某个主题。RSS 内容包含中文摘要、为什么是好消息、核实说明和原文链接。
      </p>
    </header>

    <RssLinkBlock title="全部周报条目" href="/rss.xml" description="默认订阅入口，包含每期周报里发布的条目。" />

    <section class="grid gap-3">
      <h2 class="text-xl font-semibold text-ink">按主题订阅</h2>
      <div class="grid gap-3">
        {topicDefinitions.map((topic) => (
          <RssLinkBlock title={topic.label} href={topic.rssPath} description={topic.description} />
        ))}
      </div>
    </section>

    <section class="rounded-lg border border-border bg-surface-muted p-5">
      <h2 class="text-lg font-semibold text-ink">怎么使用 RSS</h2>
      <p class="mt-2 text-sm leading-7 text-muted">
        复制上面的订阅链接，添加到你常用的 RSS 阅读器里，就能在自己的信息流中接收周报更新。你不需要注册账号，也不需要依赖社交平台推荐。
      </p>
    </section>
  </section>
</BaseLayout>
