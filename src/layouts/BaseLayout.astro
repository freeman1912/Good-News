---
import "../styles/global.css";
import { site } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;

const navItems = [
  { href: "/", label: "周报" },
  { href: "/archive", label: "归档" },
  { href: "/rss", label: "RSS" },
  { href: "/about", label: "关于" },
  { href: "/submit", label: "提交线索" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-border/80 bg-neutral/92 backdrop-blur">
      <nav
        class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-3 px-4 py-4 sm:flex-row sm:items-center sm:gap-6 sm:px-6"
        aria-label="主导航"
      >
        <a href="/" class="flex min-w-0 flex-col leading-tight">
          <span class="text-lg font-semibold tracking-normal text-ink">好消息周报</span>
          <span class="text-xs text-muted">Good News Weekly</span>
        </a>
        <div class="flex flex-wrap items-center gap-1 text-sm text-muted">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="shrink-0 rounded-sm px-2.5 py-1.5 transition hover:bg-surface-muted hover:text-ink"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
